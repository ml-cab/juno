<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Suppress Netty/gRPC transport noise -->
  <logger name="io.grpc.netty.shaded.io.grpc.netty.NettyClientHandler" level="OFF"/>
  <logger name="io.grpc.netty.shaded.io.grpc.netty.NettyServerHandler" level="OFF"/>
  <logger name="io.grpc.netty.shaded.io.netty"                         level="OFF"/>
  <logger name="io.grpc.netty.shaded.io.grpc.netty"                    level="OFF"/>
  <logger name="io.grpc.netty.shaded"                                   level="ERROR"/>
  <logger name="io.netty"                                                level="ERROR"/>
  <logger name="io.grpc"                                                 level="ERROR"/>

  <root level="WARN">
    <appender-ref ref="STDOUT"/>
  </root>

</configuration>